<script>
(function(){
  var DASH_URL = "https://apps.thrivingscholars.com/dashboard";
  if (typeof window.__TS_EXAM_DONE === "undefined") window.__TS_EXAM_DONE = false;

  function examDone(){
    return !!window.__TS_EXAM_DONE || !!window.__TS_SUBMIT_ONCE;
  }

  function applyDoneUI(){
    try {
      if (examDone()) document.body.classList.add("ts-exam-done");
      else document.body.classList.remove("ts-exam-done");
    } catch(_) {}
  }

  function goWorkspace(){
    window.location.href = DASH_URL;
  }

  function wrapSubmitExam(){
    var orig = window.submitExam;
    if (typeof orig !== "function") return;
    if (orig.__TS_WRAPPED_DONE) return;

    function wrappedSubmitExam(){
      try { window.__TS_EXAM_DONE = true; } catch(_) {}
      applyDoneUI();
      return orig.apply(this, arguments);
    }
    wrappedSubmitExam.__TS_WRAPPED_DONE = true;
    try { window.submitExam = wrappedSubmitExam; } catch(_) {}
  }

  function bindBtn(){
    var b = document.getElementById("tsWorkspaceBtn");
    if (!b) return;
    if (b.getAttribute("data-bound")) return;
    b.setAttribute("data-bound","1");

    b.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();
      if (examDone()) {
        goWorkspace();
        return;
      }
      if (window.confirm("Are you sure you want to go back? Your progress on the current test will be lost.")) {
        goWorkspace();
      }
    }, true);
  }

  window.addEventListener("beforeunload", function(e){
    if (examDone()) return;
    e.preventDefault();
    e.returnValue = "";
    return "";
  });

  function boot(){
    applyDoneUI();
    wrapSubmitExam();
    bindBtn();
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", boot);
  else boot();
})();
</script>
