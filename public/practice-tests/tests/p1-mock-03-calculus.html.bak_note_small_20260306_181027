function startExam() {
  const nameInput = document.getElementById("student-name").value.trim();
  const emailInput = document.getElementById("studentEmail").value.trim();
  const testSelect = document.getElementById("test-date").value;

  if (!nameInput) {
    alert("Please enter your full name before starting the exam.");
    return;
  }

  if (!emailInput || !emailInput.includes("@")) {
    alert("Please enter a valid email address.");
    return;
  }

  studentName = nameInput;
  testSession = testSelect;

  document.getElementById("instructions").style.display = "none";
  document.getElementById("exam-interface").style.display = "block";
  timerInterval = setInterval(updateTimer, 1000);
  renderQuestion();
}



  function updateTimer() {
    if (minutes === 0 && seconds === 0) {
      clearInterval(timerInterval);
      submitExam();
      return;
    }
    if (seconds === 0) {
      minutes--;
      seconds = 59;
    } else {
      seconds--;
    }
    const mm = minutes.toString().padStart(2, '0');
    const ss = seconds.toString().padStart(2, '0');
    timerDisplay.textContent = `${mm}:${ss}`;
  }

  
function prevQuestion() {
  if (current > 0) {
    timeSpent[current] += (Date.now() - lastTimestamp) / 1000; // record time spent
    current--;
    lastTimestamp = Date.now(); // reset timestamp for new question
    renderQuestion();
  }
}

function updateNavigatorButton(index) {
  const btn = document.getElementById(`nav-btn-${index}`);
  if (!btn) return;
  if (flags[index]) {
    btn.style.backgroundColor = "gold";
    btn.style.fontWeight = "bold";
    btn.textContent = `⚑ ${index + 1}`;
  } else {
    btn.style.backgroundColor = "";
    btn.style.fontWeight = "normal";
    btn.textContent = `${index + 1}`;
  }
}

