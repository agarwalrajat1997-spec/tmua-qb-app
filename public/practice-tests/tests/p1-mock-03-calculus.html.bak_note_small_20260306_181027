<script>
/* TS_TMUA_SCORE9_HELPER_V6 */
(function(){
  function clamp(x,a,b){ return Math.max(a, Math.min(b, x)); }
  window.TS_TMUA_SCORING_PDF = "";

  window.TS_TMUA_SCORE9 = function(rawCorrect, totalQuestions, thresholdRaw){
    var raw = Number(rawCorrect || 0);
    var total = Number(totalQuestions || 20);
    var thr = Number(thresholdRaw || 6);
    if (!isFinite(raw) || !isFinite(total) || total <= 0) return 1.0;
    if (raw <= thr) return 1.0;
    var frac = (raw - thr) / (total - thr);
    var score9 = 1.0 + frac * 8.0;
    score9 = clamp(score9, 1.0, 9.0);
    return Math.round(score9 * 10) / 10;
  };

  window.TS_TMUA_SCORE9_BLOCK = function(opts){
    opts = opts || {};
    var totalQ = Number(opts.totalQ || 20);
    var thr = Number(("thr" in opts) ? opts.thr : 6);
    var scoringPdfUrl = String(opts.scoringPdfUrl || window.TS_TMUA_SCORING_PDF || "").trim();

    function fmt(x){
      var n = Number(x);
      if (!isFinite(n)) n = 1.0;
      return n.toFixed(1);
    }

    var overallRaw = Number(opts.overallRaw || 0);
    var overall9 = window.TS_TMUA_SCORE9(overallRaw, totalQ, thr);

    var p1Raw = ("p1Raw" in opts) ? Number(opts.p1Raw || 0) : null;
    var p2Raw = ("p2Raw" in opts) ? Number(opts.p2Raw || 0) : null;
    var hasPapers = (p1Raw !== null && p2Raw !== null);

    var inner = ''
      + '<div class="ts-score9-wrap">'
      + '  <div class="ts-score9-row">'
      + '    <div>'
      + '      <div class="ts-score9-title">Estimated TMUA Score</div>'
      + '      <div class="ts-score9-sub">Scale 1.0–9.0 (approx). Threshold anchored at raw ' + thr + '.</div>'
      + '    </div>'
      + '    <div class="ts-score9-chip">' + fmt(overall9) + ' / 9.0</div>'
      + '  </div>';

    if (hasPapers){
      var p1_9 = window.TS_TMUA_SCORE9(p1Raw, 20, thr);
      var p2_9 = window.TS_TMUA_SCORE9(p2Raw, 20, thr);
      inner += ''
        + '  <div class="ts-score9-grid">'
        + '    <div class="ts-score9-card"><h4>Paper 1</h4><div class="ts-score9-big">' + fmt(p1_9) + '</div><div class="ts-score9-small">from ' + p1Raw + '/20</div></div>'
        + '    <div class="ts-score9-card"><h4>Paper 2</h4><div class="ts-score9-big">' + fmt(p2_9) + '</div><div class="ts-score9-small">from ' + p2Raw + '/20</div></div>'
        + '  </div>';
    } else {
      inner += '<div style="margin-top:12px;font-family:Arial,sans-serif;color:#555;font-size:12px;">Based on ' + overallRaw + ' / ' + totalQ + ' correct.</div>';
    }

    inner += ''
      + '  <div class="ts-score9-note">'
      + '    <div class="ts-score9-note__asterisk">*</div>'
      + '    <div class="ts-score9-note__text">'
      + '      <p class="ts-score9-note__title">Note</p>'
      + '      <p class="ts-score9-note__sub">This TMUA score is an approximate mapping based on your raw correct count. It is not an official UAT-UK conversion.</p>'
      + (scoringPdfUrl ? ('<a class="ts-score9-note__link" href="' + scoringPdfUrl + '" target="_blank" rel="noopener noreferrer">View scoring PDF</a>') : '')
      + '    </div>'
      + '  </div>'
      + '</div>';

    return inner;
  };
})();
</script>
