function generateNavigatorButtons() {
  const grid = document.getElementById("navigator-grid");
  grid.innerHTML = ""; // Clear previous buttons

  // ✅ Set heading to Paper 1 or Paper 2
  document.getElementById("navigator-heading").textContent = (paper === 1) ? "Paper 1" : "Paper 2";

  const offset = (paper === 1) ? 0 : 20;

  for (let i = 0; i < 20; i++) {
    const actualIndex = offset + i;

    const btn = document.createElement("button");
    btn.textContent = i + 1;
    btn.dataset.index = actualIndex;
    btn.id = `nav-btn-${actualIndex}`;
    btn.style.padding = "10px";

    btn.onclick = function () {
      jumpTo(actualIndex);
    };

    grid.appendChild(btn);
  }

  // Update buttons’ flag styling
  for (let i = 0; i < 20; i++) {
    updateNavigatorButton(offset + i);
  }
}


function showBreakScreen() {
  clearInterval(timerInterval);

  document.getElementById("exam-interface").style.display = "none";
  document.getElementById("break-screen").style.display = "block";

  breakMinutes = 5;
  breakSeconds = 0;

  breakInterval = setInterval(updateBreakTimer, 1000);
}



function skipBreak() {
  clearInterval(breakInterval);
  clearInterval(timerInterval); // stop any previous timer

  // ✅ Reset timer to 75:00
  minutes = 75;
  seconds = 0;

  // ✅ Start new 75-minute timer
  timerInterval = setInterval(updateTimer, 1000);

  // ✅ Switch to Paper 2
  paper = 2;
  current = 20;
  lastTimestamp = Date.now(); // ✅ Start time tracking for Paper 2

  renderQuestion();

  // ✅ Regenerate navigator buttons for Paper 2
  generateNavigatorButtons();

  document.getElementById("break-screen").style.display = "none";
  document.getElementById("exam-interface").style.display = "block";
}




function updateNavigatorButton(index) {
  const btn = document.getElementById(`nav-btn-${index}`);
  if (!btn) return;

  if (flags[index]) {
    btn.style.backgroundColor = "gold";
    btn.style.fontWeight = "bold";
    btn.textContent = `⚑ ${parseInt(btn.textContent)}`; // retain 1–20 display
  } else {
    btn.style.backgroundColor = "";
    btn.style.fontWeight = "normal";
    btn.textContent = btn.textContent.replace("⚑", "").trim();
  }
}

window.onload = function () {
  generateNavigatorButtons();
  for (let i = 0; i < 20; i++) updateNavigatorButton(i);
};


