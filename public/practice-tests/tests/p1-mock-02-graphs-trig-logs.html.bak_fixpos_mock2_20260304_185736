<button type="button" class="ts-workspace-btn" id="tsWorkspaceBtn" aria-label="Back to TMUA Workspace">
  &larr; TMUA Workspace
</button>

<script>
(function(){
  var DASH_URL = "https://apps.thrivingscholars.com/dashboard";

  // When true, we warn on refresh/close/navigate-away.
  // We disable it only when the user confirms leaving via our button.
  var tsWarnOnLeave = true;

  function confirmLeave(){
    return window.confirm("Are you sure you want to go back? Your progress on the current test will be lost.");
  }

  function goWorkspace(){
    window.location.href = DASH_URL;
  }

  function bindBtn(){
    var b = document.getElementById("tsWorkspaceBtn");
    if (!b) return;
    if (b.getAttribute("data-bound")) return;
    b.setAttribute("data-bound","1");

    b.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();

      if (confirmLeave()) {
        tsWarnOnLeave = false; // allow navigation without extra browser prompt
        goWorkspace();
      }
    }, true);
  }

  // Refresh/close/tab change warnings:
  window.addEventListener("beforeunload", function(e){
    if (!tsWarnOnLeave) return;
    // Modern browsers ignore custom text, but setting returnValue triggers the prompt.
    e.preventDefault();
    e.returnValue = "";
    return "";
  });

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindBtn);
  } else {
    bindBtn();
  }
})();
</script>
