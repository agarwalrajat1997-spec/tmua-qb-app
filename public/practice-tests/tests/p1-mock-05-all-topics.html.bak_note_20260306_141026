<!-- TS_PATCH_PORTAL_SUBMIT_V4 -->
<script>
(function(){
  try { window.TS_TEST_ID = "tmua-mock-test-5"; } catch(_) {}
  try { window.TS_PAPER = "1"; } catch(_) {}

  function getVar(name){
    try { return Function("return (typeof " + name + " !== 'undefined') ? " + name + " : undefined;")(); }
    catch(e){ return undefined; }
  }
  function safeArr(x){ return Array.isArray(x) ? x : []; }

  function computePayload(){
    var ca = safeArr(window.correctAnswers || getVar("correctAnswers"));
    var ua = safeArr(window.userAnswers || getVar("userAnswers"));
    var ts = safeArr(window.timeSpent || getVar("timeSpent"));
    var fl = safeArr(window.flags || getVar("flags"));

    var n = ca.length || ua.length || 0;

    var score = 0;
    var incorrect = [];
    for (var i=0; i<n; i++){
      if (ua[i] === ca[i] && ua[i] !== null && typeof ua[i] !== "undefined") score++;
      if (ua[i] !== ca[i]) incorrect.push(i+1);
    }

    var title = "TMUA Practice Test";
    try {
      var el = document.getElementById("test-title");
      if (el && el.textContent) title = el.textContent.trim();
    } catch(_) {}

    var studentEmail = "";
    try {
      var em = document.getElementById("studentEmail");
      if (em && em.value) studentEmail = String(em.value).trim();
    } catch(_) {}

    return {
      test_id: (window.TS_TEST_ID || "tmua-mock-test-5"),
      test_title: title,
      paper: (window.TS_PAPER || "1"),
      total_questions: n,
      score: score,
      answers: ua,
      correct_answers: ca,
      time_spent: ts,
      flags: fl,
      incorrect: incorrect,
      student_email: studentEmail
    };
  }

  function submitToPortal(){
    if (window.__TS_SUBMIT_ONCE) return;
    window.__TS_SUBMIT_ONCE = true;

    var payload = computePayload();

    fetch("/api/practice-tests/submit", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify(payload)
    })
    .then(function(r){
      return r.text().then(function(t){
        console.log("TS_SUBMIT status:", r.status);
        if (t) console.log("TS_SUBMIT body:", t);
      });
    })
    .catch(function(e){
      console.error("TS_SUBMIT error:", e);
    });
  }

  function wrapSubmitExam(){
    var orig = window.submitExam || getVar("submitExam");
    if (typeof orig !== "function") return;
    if (orig.__TS_WRAPPED) return;

    function wrappedSubmitExam(){
      var ret;
      try { ret = orig.apply(this, arguments); }
      finally { try { submitToPortal(); } catch(_) {} }
      return ret;
    }
    wrappedSubmitExam.__TS_WRAPPED = true;
    try { window.submitExam = wrappedSubmitExam; } catch(_) {}
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", wrapSubmitExam);
  } else {
    wrapSubmitExam();
  }
})();
</script>
