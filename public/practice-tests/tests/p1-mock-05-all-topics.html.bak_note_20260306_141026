<script>
(function(){
  var PDF_URL = "https://uat-wp.s3.eu-west-2.amazonaws.com/wp-content/uploads/2025/11/14082812/TMUA_Explanation_of_Results-October2025.pdf";

  function makeNoteEl(){
    var wrap = document.createElement("div");
    wrap.className = "ts-score-note";
    wrap.setAttribute("role","note");
    wrap.setAttribute("aria-label","TMUA score scaling note");

    wrap.innerHTML =
      '<div class="ts-score-note__row">' +
      '  <div class="ts-score-note__left">' +
      '    <div class="ts-score-note__asterisk">*</div>' +
      '    <div class="ts-score-note__text">' +
      '      <p class="ts-score-note__title">TMUA scoring note</p>' +
      '      <p class="ts-score-note__sub">The /9.0 estimate is an approximate scaling reference. See the official “Explanation of Results” PDF for how TMUA scores are reported.</p>' +
      '    </div>' +
      '  </div>' +
      '  <a class="ts-score-note__btn" href="' + PDF_URL + '" target="_blank" rel="noopener noreferrer" aria-label="Open official TMUA score explanation PDF">' +
      '    <svg class="ts-score-note__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">' +
      '      <path d="M14 3h7v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>' +
      '      <path d="M10 14L21 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>' +
      '      <path d="M21 14v6a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>' +
      '    </svg>' +
      '  </a>' +
      '</div>';

    return wrap;
  }

  function injectOnce(){
    try {
      if (document.getElementById("tsScoreNoteInjected")) return;

      var anchor = document.querySelector(".ts-score9-wrap"); // your TMUA /9 UI block
      if (!anchor) return;

      // prevent duplicates inside the same score box
      var existing = anchor.querySelector(".ts-score-note");
      if (existing) return;

      var note = makeNoteEl();
      note.id = "tsScoreNoteInjected";

      // insert INSIDE the TMUA score block so it shares the same dialogue box
      anchor.appendChild(note);
    } catch(e){
      console.error("ts-score-note injection failed", e);
    }
  }

  function wrapSubmitExam(){
    var orig = window.submitExam;
    if (typeof orig !== "function") return;
    if (orig.__TS_SCORE_NOTE_WRAPPED) return;

    function wrappedSubmitExam(){
      var ret = orig.apply(this, arguments);
      // results HTML is rendered inside submitExam -> wait a tick then inject
      setTimeout(injectOnce, 0);
      setTimeout(injectOnce, 50);
      return ret;
    }
    wrappedSubmitExam.__TS_SCORE_NOTE_WRAPPED = true;
    try { window.submitExam = wrappedSubmitExam; } catch(e){}
  }

  function boot(){
    wrapSubmitExam();
    // If results are already on screen for any reason, try once
    setTimeout(injectOnce, 100);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
})();
</script>
