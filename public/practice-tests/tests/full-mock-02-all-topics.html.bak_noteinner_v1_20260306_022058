  document.getElementById("navigator-heading").textContent = (paper === 1) ? "Paper 1" : "Paper 2";

  const offset = (paper === 1) ? 0 : 20;

  for (let i = 0; i < 20; i++) {
    const actualIndex = offset + i;

    const btn = document.createElement("button");
    btn.textContent = i + 1;
    btn.dataset.index = actualIndex;
    btn.id = `nav-btn-${actualIndex}`;
    btn.style.padding = "10px";

    btn.onclick = function () {
      jumpTo(actualIndex);
