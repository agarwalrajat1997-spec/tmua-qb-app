    timeSpent[current] += (Date.now() - lastTimestamp) / 1000;
    lastTimestamp = Date.now();

    if (paper === 1) {
      // ⛔️ Don't submit here — go to the break screen
      showBreakScreen();
    } else {
      // ✅ Paper 2 end: now submit the entire test
      submitExam();
    }
    return;
  }

  if (seconds === 0) {
    minutes--;
    seconds = 59;
  } else {
    seconds--;
  }

  const mm = minutes.toString().padStart(2, '0');
  const ss = seconds.toString().padStart(2, '0');
  timerDisplay.textContent = `${mm}:${ss}`;
}


  
