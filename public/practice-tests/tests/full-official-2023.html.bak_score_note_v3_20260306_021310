  function isTypingTarget(t){
    if (!t) return false;
    var tag = (t.tagName || "").toUpperCase();
    return t.isContentEditable || tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT";
  }

  function bindHotkeys(){
    window.addEventListener("keydown", function(e){
      if (!e.altKey) return;
      if (e.ctrlKey || e.metaKey) return;
      if (isTypingTarget(e.target)) return;

      var k = (e.key || "").toLowerCase();
      if (k === "n") {
        e.preventDefault(); e.stopPropagation();
        if (typeof nextQuestion === "function") nextQuestion();
        else if (window.NAV && typeof window.NAV.next === "function") window.NAV.next();
      } else if (k === "p") {
        e.preventDefault(); e.stopPropagation();
        if (typeof prevQuestion === "function") prevQuestion();
        else if (window.NAV && typeof window.NAV.prev === "function") window.NAV.prev();
      }
    }, true);
  }

  function bootPatch(){
    try { bindHotkeys(); } catch(_) {}
    try { disableRightClick(); } catch(_) {}
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootPatch);
  } else {
    bootPatch();
