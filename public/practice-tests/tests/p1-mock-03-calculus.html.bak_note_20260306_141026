  function examDone(){
    return !!window.__TS_EXAM_DONE || !!window.__TS_SUBMIT_ONCE;
  }

  function applyDoneUI(){
    try {
      if (examDone()) document.body.classList.add("ts-exam-done");
      else document.body.classList.remove("ts-exam-done");
    } catch(_) {}
  }

  function confirmLeave(){
    return window.confirm("Are you sure you want to go back? Your progress on the current test will be lost.");
  }

