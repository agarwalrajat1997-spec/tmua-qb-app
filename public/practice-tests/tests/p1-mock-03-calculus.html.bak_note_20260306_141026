  /* /TS_SUBMIT_MOCK3_V1 */
clearInterval(timerInterval);

  // â±ï¸ Record final question time
  timeSpent[current] += (Date.now() - lastTimestamp) / 1000;

  // âœ… Calculate score
  let score = 0;
  for (let i = 0; i < correctAnswers.length; i++) {
    if (userAnswers[i] === correctAnswers[i]) {
      score++;
    }
  }

  // âœ… Prepare timestamp
  const timestamp = new Date().toLocaleString();

  // âœ… Find incorrect question numbers
  let incorrectList = [];
  for (let i = 0; i < correctAnswers.length; i++) {
    if (userAnswers[i] !== correctAnswers[i]) {
      incorrectList.push(i + 1);
    }

  /* TS_SUBMIT_MOCK3_V1 */
  try {
    var ca = (Array.isArray(window.correctAnswers) ? window.correctAnswers : (typeof correctAnswers !== "undefined" ? correctAnswers : []));
    var ua = (Array.isArray(window.userAnswers) ? window.userAnswers : (typeof userAnswers !== "undefined" ? userAnswers : []));
    var ts = (Array.isArray(window.timeSpent) ? window.timeSpent : (typeof timeSpent !== "undefined" ? timeSpent : []));
    var fl = (Array.isArray(window.flags) ? window.flags : (typeof flags !== "undefined" ? flags : []));

    var computedScore = 0;
    for (var i = 0; i < ca.length; i++) { if (ua[i] === ca[i]) computedScore++; }

    var incorrectLocal = [];
    for (var j = 0; j < ca.length; j++) { if (ua[j] !== ca[j]) incorrectLocal.push(j + 1); }

    fetch("/api/practice-tests/submit", {
      method: "POST",
