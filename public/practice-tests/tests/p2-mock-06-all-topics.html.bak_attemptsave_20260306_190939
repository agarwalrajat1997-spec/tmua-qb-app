(function(){
  function clamp(x,a,b){ return Math.max(a, Math.min(b, x)); }
  window.TS_TMUA_SCORING_PDF = "https://uat-wp.s3.eu-west-2.amazonaws.com/wp-content/uploads/2025/11/14082812/TMUA_Explanation_of_Results-October2025.pdf";

  window.TS_TMUA_SCORE9 = function(rawCorrect, totalQuestions, thresholdRaw){
    var raw = Number(rawCorrect || 0);
    var total = Number(totalQuestions || 20);
    var thr = Number(thresholdRaw || 6);
    if (!isFinite(raw) || !isFinite(total) || total <= 0) return 1.0;
    if (raw <= thr) return 1.0;
    var frac = (raw - thr) / (total - thr);
    var score9 = 1.0 + frac * 8.0;
    score9 = clamp(score9, 1.0, 9.0);
    return Math.round(score9 * 10) / 10;
  };

  window.TS_TMUA_SCORE9_BLOCK = function(opts){
    opts = opts || {};
    var totalQ = Number(opts.totalQ || 20);
    var thr = Number(("thr" in opts) ? opts.thr : 6);
    var scoringPdfUrl = String(opts.scoringPdfUrl || window.TS_TMUA_SCORING_PDF || "").trim();

    function fmt(x){
      var n = Number(x);
      if (!isFinite(n)) n = 1.0;
      return n.toFixed(1);
    }

    var overallRaw = Number(opts.overallRaw || 0);
    var overall9 = window.TS_TMUA_SCORE9(overallRaw, totalQ, thr);

    var p1Raw = ("p1Raw" in opts) ? Number(opts.p1Raw || 0) : null;
    var p2Raw = ("p2Raw" in opts) ? Number(opts.p2Raw || 0) : null;
    var hasPapers = (p1Raw !== null && p2Raw !== null);

    var inner = ''
      + '<div class="ts-score9-wrap">'
      + '  <div class="ts-score9-row">'
      + '    <div>'
      + '      <div class="ts-score9-title">Estimated TMUA Score</div>'
      + '      <div class="ts-score9-sub">Scale 1.0–9.0 (approx). Threshold anchored at raw ' + thr + '.</div>'
      + '    </div>'
      + '    <div class="ts-score9-chip">' + fmt(overall9) + ' / 9.0</div>'
      + '  </div>';

    if (hasPapers){
      var p1_9 = window.TS_TMUA_SCORE9(p1Raw, 20, thr);
      var p2_9 = window.TS_TMUA_SCORE9(p2Raw, 20, thr);
      inner += ''
        + '  <div class="ts-score9-grid">'
        + '    <div class="ts-score9-card"><h4>Paper 1</h4><div class="ts-score9-big">' + fmt(p1_9) + '</div><div class="ts-score9-small">from ' + p1Raw + '/20</div></div>'
        + '    <div class="ts-score9-card"><h4>Paper 2</h4><div class="ts-score9-big">' + fmt(p2_9) + '</div><div class="ts-score9-small">from ' + p2Raw + '/20</div></div>'
        + '  </div>';
    } else {
      inner += '<div style="margin-top:12px;font-family:Arial,sans-serif;color:#555;font-size:12px;">Based on ' + overallRaw + ' / ' + totalQ + ' correct.</div>';
    }

    inner += ''
      + '  <div class="ts-score9-note">'
      + '    <div class="ts-score9-note__asterisk">*</div>'
      + '    <div class="ts-score9-note__text">'
      + '      <p class="ts-score9-note__title">Note</p>'
      + '      <p class="ts-score9-note__sub">This TMUA score is an approximate mapping based on your raw correct count. It is not an official UAT-UK conversion.</p>'
      + '    </div>'
      + (scoringPdfUrl
          ? '    <a class="ts-score9-note__btn" href="' + scoringPdfUrl + '" target="_blank" rel="noopener noreferrer" aria-label="Open scoring PDF" title="Open scoring PDF">'
            + '      <svg class="ts-score9-note__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">'
            + '        <path d="M8 8h8v8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'
            + '        <path d="M8 16L16 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'
            + '        <path d="M16 13v5H3V5h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>'
            + '      </svg>'
            + '    </a>'
          : '')
      + '  </div>'
      + '</div>';

    return inner;
  };
})();
</script>
<!-- TS_PATCH_WORKSPACE_BTN_V8 -->
<style>
.ts-workspace-btn{
  position: fixed;
  left: 14px;
  bottom: 7px;
  z-index: 2000;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 12px;
  border-radius: 999px;
  background: rgba(255,255,255,0.92);
  border: 1px solid rgba(17,24,39,0.18);
  box-shadow: 0 10px 24px rgba(0,0,0,0.10);
  color: rgba(17,24,39,0.86);
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.02em;
  cursor: pointer;
  user-select: none;
}
body.ts-exam-done .ts-workspace-btn{
  background: rgba(246, 196, 74, 0.95);
  border: 1px solid rgba(146, 98, 0, 0.30);
  color: rgba(43, 26, 0, 0.92);
  font-weight: 800;
}
</style>

<button type="button" class="ts-workspace-btn" id="tsWorkspaceBtn" aria-label="Back to TMUA Workspace">
  &larr; TMUA Workspace
</button>

<script>
(function(){
  var DASH_URL = "https://apps.thrivingscholars.com/dashboard";
  if (typeof window.__TS_EXAM_DONE === "undefined") window.__TS_EXAM_DONE = false;

  function examDone(){
    return !!window.__TS_EXAM_DONE || !!window.__TS_SUBMIT_ONCE;
  }

  function applyDoneUI(){
    try {
      if (examDone()) document.body.classList.add("ts-exam-done");
      else document.body.classList.remove("ts-exam-done");
    } catch(_) {}
  }

  function goWorkspace(){
    window.location.href = DASH_URL;
  }

  function wrapSubmitExam(){
    var orig = window.submitExam;
    if (typeof orig !== "function") return;
    if (orig.__TS_WRAPPED_DONE) return;

    function wrappedSubmitExam(){
      try { window.__TS_EXAM_DONE = true; } catch(_) {}
      applyDoneUI();
      return orig.apply(this, arguments);
    }
    wrappedSubmitExam.__TS_WRAPPED_DONE = true;
    try { window.submitExam = wrappedSubmitExam; } catch(_) {}
  }

  function bindBtn(){
    var b = document.getElementById("tsWorkspaceBtn");
    if (!b) return;
    if (b.getAttribute("data-bound")) return;
    b.setAttribute("data-bound","1");

    b.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();
      if (examDone()) {
        goWorkspace();
        return;
      }
      if (window.confirm("Are you sure you want to go back? Your progress on the current test will be lost.")) {
        goWorkspace();
      }
    }, true);
  }

  window.addEventListener("beforeunload", function(e){
    if (examDone()) return;
    e.preventDefault();
    e.returnValue = "";
    return "";
  });

  function boot(){
    applyDoneUI();
    wrapSubmitExam();
    bindBtn();
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", boot);
  else boot();
})();
</script>
<!-- /TS_PATCH_WORKSPACE_BTN_V8 -->
</body>
</html>

