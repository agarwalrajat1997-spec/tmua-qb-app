}

function bindHotkeys(){
  // capture=true helps â€œbeatâ€ some default handlers
  window.addEventListener("keydown", (e) => {
    if (!e.altKey) return;
    if (e.ctrlKey || e.metaKey) return;     // avoid collisions like Ctrl/Command combos
