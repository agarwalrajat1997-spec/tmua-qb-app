    :root{
      --blue:#0074c1;
      --blue2:#005fa3;
      --bg:#ffffff;
      --text:#0b1220;
      --muted:#475569;
      --border:#cbd5e1;
      --chip:#eef6ff;
      --good:#22c55e;
      --bad:#ef4444;
      --warn:#fbbf24;
      --card:#ffffff;
      --shadow:0 10px 24px rgba(15,23,42,.10);
      --radius:14px;
      --pad:20px;
      --font:"Georgia", serif;
      --calcIcon: url("https://static.wixstatic.com/media/98f2c5_b313bf07122944b5b74d5e5c9fd53a00~mv2.png");
    }

    body{
      margin:0;
      font-family:var(--font);
      background:var(--bg);
      color:var(--text);
    }
/* Back to main menu button (distinct) */
.btn.menu{
  background:#fbbf24;          /* amber */
  color:#111827;
  border:1px solid rgba(17,24,39,.25);
  font-weight:900;
}
.btn.menu:hover{ filter:brightness(.98); }
.btn.menu:active{ transform:translateY(1px); }
    /* Header */
    .header{
      background:var(--blue);
      color:white;
      padding:10px 18px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
    }
    .header-left{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:260px;
    }
    .brand{
      font-weight:800;
      font-size:18px;
      line-height:1.1;
    }
    .subbrand{
      font-size:12px;
      opacity:.9;
      margin-top:2px;
    }

    .header-right{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.14);
      border:1px solid rgba(255,255,255,.25);
      font-size:13px;
      white-space:nowrap;
    }
    .pill strong{ font-weight:800; }

    .btn{
      appearance:none;
      border:none;
      background:var(--blue2);
      color:white;
      padding:8px 12px;
      border-radius:8px;
      cursor:pointer;
      font-size:14px;
      line-height:1;
    }
    .btn:hover{ filter:brightness(.98); }
    .btn:active{ transform:translateY(1px); }

    .btn.outline{
      background:transparent;
      border:1px solid rgba(255,255,255,.6);
    }

    .btn.light{
      background:white;
      color:#111827;
      border:1px solid rgba(255,255,255,.6);
    }

    /* Layout */
    .container{
      padding: 18px 22px 90px;
      max-width: 1200px;
      margin: 0 auto;
      font-size:19px;
      line-height:1.65;
      box-sizing:border-box;
    }

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      flex-wrap:wrap;
      margin: 14px 0 12px;
    }

    .chips{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }
    .chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      background:var(--chip);
      border:1px solid #dbeafe;
      color:#0b3b66;
      border-radius:999px;
      font-size:13px;
    }
    .chip .dot{
      width:8px;height:8px;border-radius:50%;
      background:#60a5fa;
      display:inline-block;
    }

    .save-indicator{
      font-size:12px;
      color:rgba(255,255,255,.9);
      padding:6px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.25);
      background:rgba(255,255,255,.12);
      display:none;
    }

    /* Question Card */
    .qcard{
      background:var(--card);
      border:1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px 18px 14px;
    }

    .qhead{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:10px;
    }

    .qtitle{
      display:flex;
      align-items:center;
      gap:10px;
      font-size:22px;
      font-weight:800;
      margin:0;
    }
    .qtitle .calc{
      width:18px;height:18px;
      background-image:var(--calcIcon);
      background-size:contain;
      background-repeat:no-repeat;
      background-position:center;
      display:inline-block;
      filter: drop-shadow(0 1px 1px rgba(0,0,0,.12));
    }

    .qmeta{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
      justify-content:flex-end;
    }
    .meta-pill{
      font-size:12px;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid #e5e7eb;
      background:#f9fafb;
      color:#111827;
      white-space:nowrap;
    }
    .meta-pill.good{ border-color: rgba(34,197,94,.35); background: rgba(34,197,94,.10); }
    .meta-pill.bad{ border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.10); }
    .meta-pill.warn{ border-color: rgba(251,191,36,.45); background: rgba(251,191,36,.12); }

    .qbody{
      margin-top:10px;
    }
    .qbody p{ margin: 12px 0; }

    /* Media (images) */
    .question-media{
      margin: 14px 0 18px;
      display:flex;
      justify-content:center;
    }
    .question-media img{
      display:block;
      max-width: 340px;
      width:100%;
      height:auto;
      border:1.5px solid #e5e7eb;
      border-radius:12px;
      padding:10px;
      background:#fff;
    }
    .media-caption{
      text-align:center;
      color:var(--muted);
      font-size:13px;
      margin-top:8px;
    }

    /* Options */
    .options{
      margin-top: 18px;
      margin-bottom: 10px;
    }
    .option{
      display:block;
      padding:10px 12px;
      border:1px solid #e5e7eb;
      border-radius:12px;
      margin:10px 0;
      cursor:pointer;
      background:#fff;
      transition: transform .05s ease, border-color .12s ease, background .12s ease;
    }
    .option:hover{
      transform: translateY(-1px);
      border-color:#c7d2fe;
      background:#fafbff;
    }
    .option-row{
      display:flex;
      align-items:flex-start;
      gap:10px;
    }
    input[type="radio"]{
      transform:scale(1.25);
      margin-top:3px;
      cursor:pointer;
    }

    .option.correct{
      border-color: rgba(34,197,94,.35);
      background: rgba(34,197,94,.08);
    }
    .option.wrong{
      border-color: rgba(239,68,68,.35);
      background: rgba(239,68,68,.08);
    }

    /* Feedback + solution */
    .feedback{
      margin: 10px 0 0;
      padding: 10px 12px;
      border-radius: 12px;
      border:1px solid #e5e7eb;
      background:#f9fafb;
      font-size:16px;
    }
    .feedback.good{ border-color: rgba(34,197,94,.35); background: rgba(34,197,94,.10); }
    .feedback.bad{ border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.10); }

    .solution{
      margin-top:12px;
      padding: 12px 12px;
      border-radius: 12px;
      border:1px dashed #94a3b8;
      background:#fbfdff;
      display:none;
    }
    .solution h4{
      margin:0 0 8px;
      font-size:16px;
    }

    /* Footer bar */
    .footer{
      background:var(--blue);
      padding:10px 18px;
      position:fixed;
      left:0; right:0; bottom:0;
      display:flex;
      justify-content:center;
      z-index:50;
    }
    .footer-inner{
      width: min(1200px, 100%);
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
    }
    .footer-left, .footer-right{
      display:flex;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
    }
    .footer button{
      font-size:14px;
      padding:8px 12px;
      background:var(--blue2);
      color:white;
      border:none;
      border-radius:8px;
      cursor:pointer;
    }
    .footer button.outline{
      background:transparent;
      border:1px solid rgba(255,255,255,.6);
    }
    .footer button.light{
      background:white;
      color:#111827;
      border:1px solid rgba(255,255,255,.6);
    }
    .footer button:disabled{
      opacity:.55;
      cursor:not-allowed;
    }

    /* Icon toggles */
    .toggle-btn{
      background:white !important;
      color:#111827 !important;
      border:1px solid #111827 !important;
      font-weight:normal !important;
    }
    .toggle-btn.active{
      background: #fef3c7 !important;
      border:2px solid #999 !important;
      font-weight:800 !important;
    }

    /* Modals */
    .overlay{
      position:fixed; inset:0;
      background:rgba(15,23,42,.55);
      display:none;
      z-index:100;
      padding: 18px;
      overflow:auto;
    }
    .modal{
      max-width: 980px;
      margin: 28px auto;
      background:white;
      border-radius: 16px;
      box-shadow: 0 30px 70px rgba(0,0,0,.25);
      border:1px solid rgba(255,255,255,.25);
    }
    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding: 14px 16px;
      border-bottom:1px solid #e5e7eb;
    }
    .modal-header h3{
      margin:0;
      font-size:18px;
      font-weight:900;
      color:#0b1220;
    }
    .modal-body{
      padding: 14px 16px 16px;
    }
    .modal-footer{
      padding: 12px 16px;
      border-top:1px solid #e5e7eb;
      display:flex;
      justify-content:flex-end;
      gap:10px;
      flex-wrap:wrap;
    }
    .modal-close{
      background:#f3f4f6;
      border:1px solid #e5e7eb;
      border-radius:10px;
      padding:8px 10px;
      cursor:pointer;
      font-weight:700;
    }

    /* Navigator grid */
    .nav-toolbar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:10px;
    }
    .nav-grid{
      display:grid;
      grid-template-columns: repeat(10, minmax(0,1fr));
      gap:8px;
    }
    @media(max-width:820px){
      .nav-grid{ grid-template-columns: repeat(6, minmax(0,1fr)); }
    }
    @media(max-width:520px){
      .nav-grid{ grid-template-columns: repeat(5, minmax(0,1fr)); }
    }
    .nav-btn{
      border:1px solid #cbd5e1;
      background:white;
      border-radius:10px;
      padding:10px 6px;
      cursor:pointer;
      font-weight:800;
      font-size:13px;
      position:relative;
      user-select:none;
    }
    .nav-btn.current{
      outline: 3px solid rgba(59,130,246,.35);
      border-color:#60a5fa;
    }
    .nav-btn.unseen{ background:#f8fafc; }
    .nav-btn.attempted{ background:#eef2ff; }
    .nav-btn.correct{ background: rgba(34,197,94,.14); border-color: rgba(34,197,94,.35); }
    .nav-btn.incorrect{ background: rgba(239,68,68,.12); border-color: rgba(239,68,68,.35); }
    .nav-btn.flagged{ box-shadow: inset 0 0 0 2px rgba(251,191,36,.85); }
    .nav-btn.saved{ box-shadow: inset 0 0 0 2px rgba(16,185,129,.65); }
    .nav-icons{
      position:absolute;
      right:6px;
      top:6px;
      font-size:12px;
      opacity:.9;
      display:flex;
      gap:4px;
    }

    /* Filters UI */
/* Filters UI (more efficient layout) */
.filter-grid{
  display:grid;
  gap:12px 18px;
  align-items:start;
  grid-template-columns: 320px 1fr 260px;
  grid-template-areas:
    "status  topics paper"
    "diff    topics sort";
}

#fCardStatus{ grid-area: status; }
#fCardDifficulty{ grid-area: diff; }
#fCardTopics{ grid-area: topics; }
#fCardPaper{ grid-area: paper; }
#fCardSort{ grid-area: sort; }

/* Topics: 2 columns + scroll so modal doesn't become tall */
#fTopics{
  display:grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap:10px 12px;
  max-height: 320px;
  overflow:auto;
  padding-right:6px;
}

/* Difficulty: compact grid */
#fDiffs{
  display:grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap:10px 12px;
}

/* On smaller screens: stack */
@media(max-width: 980px){
  .filter-grid{
    grid-template-columns: 1fr;
    grid-template-areas:
      "status"
      "paper"
      "diff"
      "topics"
      "sort";
  }
  #fTopics{
    grid-template-columns: 1fr;
    max-height: 360px;
  }
}

