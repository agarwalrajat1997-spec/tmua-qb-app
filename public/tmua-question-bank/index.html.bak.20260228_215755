const Media = {
  enhanceHTML(rawHtml){
    if (!rawHtml) return "";

    // Wrap so DOMParser always has a single root
    const doc = new DOMParser().parseFromString(`<div id="__r">${rawHtml}</div>`, "text/html");
    const root = doc.getElementById("__r");

    // A) Upgrade existing <img> tags
    root.querySelectorAll("img").forEach(img => {
      img.loading = img.loading || "lazy";
      img.decoding = img.decoding || "async";
      img.classList.add("qa-img", "zoomable");

      // Wrap in figure if not already wrapped
      if (!img.closest("figure.qa-figure")) {
        const fig = doc.createElement("figure");
        fig.className = "qa-figure";

        const alt = (img.getAttribute("alt") || "").trim();

        img.replaceWith(fig);
        fig.appendChild(img);

        // optional caption (remove if you donâ€™t want captions)
        if (alt) {
          const cap = doc.createElement("figcaption");
          cap.className = "qa-cap";
          cap.textContent = alt;
          fig.appendChild(cap);
        }
      }
    });

    // B) Convert plain image URLs in text into <img> figures
    const IMG_URL = /(https?:\/\/[^\s"'<>]+?\.(?:png|jpe?g|webp|gif|svg))(?:\?[^\s"'<>]*)?/ig;

    // collect text nodes (TreeWalker)
    const walker = doc.createTreeWalker(root, NodeFilter.SHOW_TEXT);
    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);

    nodes.forEach(node => {
      const txt = node.nodeValue;
      if (!txt) return;

      // quick check
      if (!IMG_URL.test(txt)) return;
      IMG_URL.lastIndex = 0;

      const frag = doc.createDocumentFragment();
      let last = 0;
      let m;

      while ((m = IMG_URL.exec(txt))) {
        const before = txt.slice(last, m.index);
        if (before) frag.appendChild(doc.createTextNode(before));

        const url = m[0];

        const fig = doc.createElement("figure");
        fig.className = "qa-figure";

        const img = doc.createElement("img");
        img.className = "qa-img zoomable";
        img.loading = "lazy";
        img.decoding = "async";
        img.src = url;
        img.alt = "Image";

        fig.appendChild(img);
        frag.appendChild(fig);

        last = m.index + url.length;
      }

      const after = txt.slice(last);
      if (after) frag.appendChild(doc.createTextNode(after));

      node.parentNode.replaceChild(frag, node);
    });

    return root.innerHTML;
  }
};

