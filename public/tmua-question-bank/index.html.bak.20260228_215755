    const nb = mb ? parseInt(mb[1], 10) : 9999;
    if (na !== nb) return na - nb;

    const ta = (ma ? ma[2] : sa).trim();
    const tb = (mb ? mb[2] : sb).trim();
    return ta.localeCompare(tb, undefined, { numeric: true, sensitivity: "base" });
  });
