  function sortQuestions(list) {
  const s = state?.filters?.sort || "topic";   // default = topic
  const copy = list.slice();

  // helper: numeric-safe comparator for question numbers (so 10 > 9)
  const cmpNum = (a, b) => {
    const na = Number(a?.numberSort);
    const nb = Number(b?.numberSort);
    if (!Number.isNaN(na) && !Number.isNaN(nb)) return na - nb;
    return String(a?.qid ?? "").localeCompare(String(b?.qid ?? ""), undefined, { numeric: true });
  };

  // helper: difficulty rank (supports strings or numbers)
  const diffKey = (q) => {
    const d = q?.difficulty;
    if (typeof d === "number") return d;

    const s = String(d ?? "").toLowerCase();
    if (s.startsWith("e")) return 1; // easy
    if (s.startsWith("m")) return 2; // medium
    if (s.startsWith("h")) return 3; // hard
    return 999; // unknown last
  };

  // helper: topic order (uses your topicIndex if present; otherwise numeric-aware)
  const topicKey = (q) => {
    if (typeof topicIndex === "function") return topicIndex(q?.topic);
    return String(q?.topic ?? "");
  };

  if (s === "difficulty") {
    // Difficulty first, then Topic, then Question #
    copy.sort((a, b) => {
      const d = diffKey(a) - diffKey(b);
      if (d !== 0) return d;

      const ta = topicKey(a);
      const tb = topicKey(b);

      // topicIndex returns numbers; fallback returns strings
      if (typeof ta === "number" && typeof tb === "number") {
        if (ta !== tb) return ta - tb;
      } else {
        const t = String(ta).localeCompare(String(tb), undefined, { numeric: true, sensitivity: "base" });
        if (t !== 0) return t;
      }

      return cmpNum(a, b);
    });
  } else if (s === "topic") {
    // Topic first, then Difficulty (inside topic), then Question #
    copy.sort((a, b) => {
      const ta = topicKey(a);
      const tb = topicKey(b);

      if (typeof ta === "number" && typeof tb === "number") {
        if (ta !== tb) return ta - tb;
      } else {
        const t = String(ta).localeCompare(String(tb), undefined, { numeric: true, sensitivity: "base" });
        if (t !== 0) return t;
      }

      const d = diffKey(a) - diffKey(b);
      if (d !== 0) return d;

      return cmpNum(a, b);
    });
  } else {
    // number
    copy.sort((a, b) => cmpNum(a, b));
  }

  return copy;
}


