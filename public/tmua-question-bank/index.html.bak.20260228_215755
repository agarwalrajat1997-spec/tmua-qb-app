          filters: { ...defaultState().filters, ...(payload.state.filters||{}) },
          ui: { ...defaultState().ui, ...(payload.state.ui||{}) },
          answers: payload.state.answers && typeof payload.state.answers === "object" ? payload.state.answers : {}
        };

        saveState();
        STATE.applyFilters();
        UI.closeBackup();
        alert("Import complete.");
      }
    };

    function toggleInArray(arr, value){
      const i = arr.indexOf(value);
      if (i >= 0) arr.splice(i, 1);
      else arr.push(value);
    }

    function buildChecks(containerId, values, selectedArr, onToggle, labelFn){
      const box = el(containerId);
      box.innerHTML = "";
      values.forEach(v => {
        const wrap = document.createElement("label");
        wrap.className = "chk";
        const input = document.createElement("input");
        input.type = "checkbox";
        input.checked = selectedArr.includes(v);
        input.onchange = () => onToggle(v);

        const span = document.createElement("span");
        span.textContent = labelFn ? labelFn(v) : v;

        wrap.appendChild(input);
        wrap.appendChild(span);
        box.appendChild(wrap);
      });
    }

    // ---------- Dashboard + Report ----------
const DASH = {
  render(){
    const stats = computeStats();

    el("dAttempted").textContent = stats.attempted;
    el("dCorrect").textContent = stats.correct;
    el("dAcc").textContent = `${stats.acc}%`;
    el("dFlagged").textContent = stats.flagged;

    el("topicBreakdown").innerHTML = formatBreakdown(stats.byTopic);
    el("diffBreakdown").innerHTML = formatBreakdown(stats.byDiff);
  }
};


    const REPORT = {
      buildText(){
        const stats = computeStats();
        const now = new Date().toLocaleString();

        let lines = [];
        lines.push(`TMUA Question Bank Report`);
        lines.push(`Date: ${now}`);
        lines.push(`Bank: ${CONFIG.QUESTION_BANK_ID}`);
        lines.push(``);
lines.push(`Overall: Attempted ${stats.attempted} | Checked ${stats.checked} | Correct ${stats.correct} | Accuracy ${stats.acc}%`);
lines.push(`Flagged: ${stats.flagged}`);
        lines.push(``);
        lines.push(`Accuracy by Topic (checked only):`);
        lines.push(formatBreakdownText(stats.byTopic));
        lines.push(``);
        lines.push(`Accuracy by Difficulty (checked only):`);
        lines.push(formatBreakdownText(stats.byDiff));
        lines.push(``);
        lines.push(`Incorrect questions (checked): ${stats.incorrectList.join(", ") || "None"}`);
        lines.push(`Flagged questions: ${stats.flaggedList.join(", ") || "None"}`);
        lines.push(`Saved questions: ${stats.savedList.join(", ") || "None"}`);
        lines.push(``);

        // per-question short summary (only attempted)
        lines.push(`Per-question (attempted):`);
        const attempted = QUESTIONS_ALL.filter(q => state.answers[q.qid]?.selected);
        attempted.sort((a,b)=>a.numberSort-b.numberSort);
        attempted.forEach(q => {
          const a = state.answers[q.qid];
          const status = a.checked ? (a.isCorrect ? "OK" : "WRONG") : "UN-CHECKED";
          lines.push(`Q${q.number} (${q.paper}) | Your: ${a.selected} | Ans: ${q.answer || "-"} | ${status}`);
        });

        return lines.join("\n");
      },

      copy(){
        const text = REPORT.buildText();
        navigator.clipboard?.writeText(text).then(()=>{
          alert("Report copied to clipboard.");
        }).catch(()=>{
          // fallback
          const ta = document.createElement("textarea");
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
          alert("Report copied to clipboard.");
        });
      },

      openMailto(){
        const subject = encodeURIComponent("TMUA Question Bank Report");
        const body = encodeURIComponent(REPORT.buildText());
        // NOTE: mailto has length limits; for very large banks, copy instead.
        window.open(`mailto:?subject=${subject}&body=${body}`, "_blank");
      }
    };

    function formatBreakdown(mapObj){
      // mapObj: {key:{correct, total}}
      const rows = Object.keys(mapObj).sort().map(k => {
        const v = mapObj[k];
        const acc = v.total ? Math.round(100*v.correct/v.total) : 0;
        return `<div class="stat-row"><span>${escapeHtml(k)}</span><strong>${v.correct}/${v.total} (${acc}%)</strong></div>`;
      });
      return rows.join("") || `<div class="small">No checked questions yet.</div>`;
    }

    function formatBreakdownText(mapObj){
      const keys = Object.keys(mapObj).sort();
      if (!keys.length) return "  (No checked questions yet.)";
      return keys.map(k => {
        const v = mapObj[k];
        const acc = v.total ? Math.round(100*v.correct/v.total) : 0;
        return `  - ${k}: ${v.correct}/${v.total} (${acc}%)`;
      }).join("\n");
    }

    function escapeHtml(s){
      return String(s).replace(/[&<>"']/g, c => ({
        "&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#039;"
      }[c]));
    }

   function computeStats(){
  let attempted = 0, checked = 0, correct = 0, flagged = 0;
  const byTopic = {};
  const byDiff = {};
  const incorrectList = [];
  const flaggedList = [];

  QUESTIONS_ALL.forEach(q => {
    const a = state.answers[q.qid] || {};
    if (a.selected) attempted++;
    if (a.flagged) { flagged++; flaggedList.push(q.number); }

    if (a.checked){
      checked++;
      if (!byTopic[q.topic]) byTopic[q.topic] = {correct:0,total:0};
      if (!byDiff[String(q.difficulty)]) byDiff[String(q.difficulty)] = {correct:0,total:0};
      byTopic[q.topic].total++;
      byDiff[String(q.difficulty)].total++;

      if (a.isCorrect){
        correct++;
        byTopic[q.topic].correct++;
        byDiff[String(q.difficulty)].correct++;
      } else {
        incorrectList.push(q.number);
      }
    }
  });

  const acc = checked ? Math.round(100 * correct / checked) : 0;
  return { attempted, checked, correct, acc, flagged, byTopic, byDiff, incorrectList, flaggedList };
}


    // ---------- Render ----------
    function render(){
      // Refresh lists
      visibleList = getVisibleList();
      navPoolList = getNavPoolList();

      // Pool counts
      el("poolCount").textContent = QUESTIONS_ALL.length;
      el("visibleCount").textContent = visibleList.length;

      // Empty state handling
      const empty = (visibleList.length === 0);
      el("emptyState").style.display = empty ? "block" : "none";
      el("qCard").style.display = empty ? "none" : "block";
      if (empty){
        el("posCounter").textContent = "0";
        el("posTotal").textContent = "0";
        renderTopChips();
        renderHeaderStats();
        return;
      }

      // Determine current qid
      if (!currentQid){
        // prefer last saved, else first in pool
        const candidate = state.lastQid && INDEX.byQid.has(state.lastQid) ? state.lastQid : null;
        const pool = getNavPoolList();
        currentQid = (candidate && pool.find(x=>x.qid===candidate)) ? candidate : pool[0].qid;
      }

      const q = INDEX.byQid.get(currentQid);
      const a = state.answers[q.qid] || {};

      // Position counter based on navigation pool
      const pool = getNavPoolList();
      const idx = pool.findIndex(x => x.qid === currentQid);
      el("posCounter").textContent = String(idx + 1);
      el("posTotal").textContent = String(pool.length);

      // Meta
      el("qTitle").textContent = `Question ${q.number}`;
      el("metaPaper").textContent = q.paper;
      el("metaTopic").textContent = q.topic + (q.subtopic ? ` â€¢ ${q.subtopic}` : "");
      el("metaDiff").textContent = `Difficulty ${q.difficulty}/5`;

      // Status pill
      const statusEl = el("metaStatus");
      statusEl.className = "meta-pill";
      const status = computeQuestionStatus(q);
      statusEl.textContent = status.label;
      if (status.kind === "correct") statusEl.classList.add("good");
      if (status.kind === "incorrect") statusEl.classList.add("bad");
      if (status.kind === "flagged" || status.kind === "saved") statusEl.classList.add("warn");

      // Prompt
      el("qPrompt").innerHTML = q.prompt_html || "";

      // Media
      renderMedia(q);

      // Options
      renderOptions(q, a);

      // Feedback
      renderFeedback(q, a);

      // Solution
      renderSolution(q, a);

      // Footer toggles
      updateToggleButtons(a);

      // Disable prev/next at edges (within nav pool)
      const prevBtn = document.querySelector(".footer-left button:nth-child(1)");
      const nextBtn = document.querySelector(".footer-left button:nth-child(2)");
      if (prevBtn) prevBtn.disabled = (idx <= 0);
      if (nextBtn) nextBtn.disabled = (idx >= pool.length - 1);

      // Chips + header stats
      renderTopChips();
      renderHeaderStats();

      // MathJax typeset
      if (window.MathJax && window.MathJax.typesetPromise){
        MathJax.typesetClear?.();
        MathJax.typesetPromise();
      }
    }
function computeQuestionStatus(q){
  const a = state.answers[q.qid] || {};
  if (a.checked){
    return a.isCorrect ? {kind:"correct", label:"Checked â€¢ Correct"} : {kind:"incorrect", label:"Checked â€¢ Incorrect"};
  }
  if (a.flagged) return {kind:"flagged", label:"Flagged"};
  if (a.selected) return {kind:"attempted", label:"Attempted"};
  return {kind:"unseen", label:"Unattempted"};
}

    function renderMedia(q){
      const wrap = el("qMedia");
      wrap.innerHTML = "";
      const assets = q.page_assets || [];
      if (!assets.length) return;

      // support both object assets + string assets
      const objAssets = assets.filter(x => x && typeof x === "object" && x.url);
      const strAssets = assets.filter(x => typeof x === "string");

      // show images (if provided)
      objAssets.forEach((a) => {
        const box = document.createElement("div");
        box.className = "question-media";
        const img = document.createElement("img");
        img.src = a.url;
        img.alt = a.label || "asset";
        box.appendChild(img);

        const cap = document.createElement("div");
        cap.className = "media-caption";
        cap.textContent = a.label || "";
        wrap.appendChild(box);
        if (a.label) wrap.appendChild(cap);
      });

      // show string captions (if any)
      if (strAssets.length){
        const cap = document.createElement("div");
        cap.className = "small";
        cap.style.marginTop = "6px";
        wrap.appendChild(cap);
      }
    }

    function renderOptions(q, a){
      const optionsEl = el("qOptions");
      optionsEl.innerHTML = "";

      q.options.forEach(opt => {
        const label = document.createElement("label");
        label.className = "option";

        const row = document.createElement("div");
        row.className = "option-row";

        const input = document.createElement("input");
        input.type = "radio";
        input.name = `qb_${q.qid}`;
        input.value = opt.label;

        if (a.selected === opt.label) input.checked = true;

        input.addEventListener("change", () => ACTIONS.setSelected(opt.label));
        label.addEventListener("click", (e) => {
          // allow clicking the whole card
          if (e.target && e.target.tagName !== "INPUT"){
            input.checked = true;
            ACTIONS.setSelected(opt.label);
          }
        });

        const content = document.createElement("div");
        content.innerHTML = `<strong style="margin-right:8px;">${escapeHtml(opt.label)}.</strong> ${opt.html || ""}`;

        row.appendChild(input);
        row.appendChild(content);
        label.appendChild(row);

        // after check: highlight correct/wrong
        if (a.checked){
          const isCorrectOpt = (opt.label === q.answer);
          const isSelected = (a.selected === opt.label);
          if (isCorrectOpt) label.classList.add("correct");
          if (isSelected && !isCorrectOpt) label.classList.add("wrong");
        }

        optionsEl.appendChild(label);
      });
    }

    function renderFeedback(q, a){
      const fb = el("qFeedback");
      fb.style.display = "none";
      fb.className = "feedback";

      if (!a.selected){
        return;
      }

  if (!a.checked){
  // Keep the state logic (selected but not checked), but show no message
  fb.style.display = "none";
  fb.innerHTML = "";
  return;
}


      fb.style.display = "block";
      if (a.isCorrect){
        fb.classList.add("good");
        fb.innerHTML = `âœ… Correct. Your answer: <strong>${escapeHtml(a.selected)}</strong>`;
      } else {
        fb.classList.add("bad");
        fb.innerHTML = `âŒ Incorrect. Your answer: <strong>${escapeHtml(a.selected)}</strong> &nbsp;|&nbsp; Correct: <strong>${escapeHtml(q.answer)}</strong>`;
      }
    }

function renderSolution(q, a){
  const solWrap = el("qSolution");
  const solBody = el("qSolutionBody");

  // Show solution automatically ONLY after the student has checked the answer
  if (!a.checked || !q.solution_html){
    solWrap.style.display = "none";
    solBody.innerHTML = "";

    // Optional hint line (only when an option is selected but not checked)
    if (a.selected && !a.checked){
      el("qHintLine").textContent = "Click â€œCheckâ€ to reveal the solution.";
    } else {
      el("qHintLine").textContent = "";
    }
    return;
  }

  el("qHintLine").textContent = "";
  solWrap.style.display = "block";
  solBody.innerHTML = q.solution_html || "";
}

function updateToggleButtons(a){
  const flagBtn = el("btnFlag");
  if (!flagBtn) return;

  if (a.flagged) flagBtn.classList.add("active");
  else flagBtn.classList.remove("active");
}

function disableRightClick(){
  document.addEventListener("contextmenu", (e) => {
    e.preventDefault();
  }, true);
}
    function renderTopChips(){
      const chips = el("activeChips");
      chips.innerHTML = "";

      const f = state.filters;
      const add = (text) => {
        const c = document.createElement("span");
        c.className = "chip";
        c.innerHTML = `<span class="dot"></span>${escapeHtml(text)}`;
        chips.appendChild(c);
      };

      if (f.status && f.status !== "all") add(`Status: ${f.status}`);
      if (f.papers.length) add(`Paper: ${f.papers.join(", ")}`);
      if (f.diffs.length) add(`Difficulty: ${f.diffs.join(", ")}`);
      if (f.topics.length) add(`Topics: ${f.topics.join(", ")}`);
    }

    function renderHeaderStats(){
      const s = computeStats();
      el("statAttempted").textContent = s.attempted;
      el("statCorrect").textContent = s.correct;
      el("statAcc").textContent = `${s.acc}%`;
    }

    // ---------- Init ----------
    function boot(){
  bindHotkeys();
  disableRightClick();   // âœ… add this line
   
      // Build initial UI filter checklists
      STATE.syncFiltersToUI();

      // Resolve starting qid
      const pool = getNavPoolList();
      if (!pool.length){
        currentQid = null;
      } else {
        const candidate = state.lastQid && INDEX.byQid.has(state.lastQid) ? state.lastQid : null;
        currentQid = (candidate && pool.find(x=>x.qid===candidate)) ? candidate : pool[0].qid;
      }
      render();

      // Persist current once on load
      if (currentQid){
        state.lastQid = currentQid;
        saveState();
      }
    }

    document.addEventListener("DOMContentLoaded", boot);
  </script>

