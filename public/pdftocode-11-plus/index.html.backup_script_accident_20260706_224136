cd C:\Users\agarw\tmua-qb-app

$Stamp = Get-Date -Format "yyyyMMdd_HHmmss"

# Find the current pitch-style HTML page.
$Candidates = Get-ChildItem . -Recurse -File -Filter *.html |
  Where-Object {
    $_.FullName -notmatch "\\node_modules\\|\\.next\\|\\.vercel\\|\\dist\\|\\build\\"
  } |
  Where-Object {
    $txt = Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue
    $txt -match "CLIENT PROOF-OF-CONCEPT|From 11\+ worksheets|Quality control layer|Live sample quiz|What this proves"
  }

if ($Candidates.Count -eq 0) {
  New-Item -ItemType Directory -Force "public\pdftocode-11-plus" | Out-Null
  $File = "public\pdftocode-11-plus\index.html"
  Write-Host "No existing page found. Creating new page at $File"
}
elseif ($Candidates.Count -eq 1) {
  $File = $Candidates[0].FullName
  Write-Host "Found page:"
  Write-Host $File
}
else {
  Write-Host "Multiple possible pages found:"
  $Candidates | Select-Object FullName, Length | Format-Table -AutoSize
  throw "Set `$File manually to the correct HTML page, then rerun the replacement part."
}

if (Test-Path $File) {
  Copy-Item $File "$File.backup_student_quiz_$Stamp" -Force
}

